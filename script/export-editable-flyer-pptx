def main():
    decks = [
        {
            "output": EXPORT_DIR / "social-flyer-editable.pptx",
            "image": EXPORT_DIR / "social-header.png",
            "spec": build_spec_social(),
            "cx": 10 * EMU_PER_INCH,
            "cy": 10 * EMU_PER_INCH,
        },
        {
            "output": EXPORT_DIR / "portrait-flyer-editable.pptx",
            "image": EXPORT_DIR / "portrait-header.png",
            "spec": build_spec_portrait(),
            "cx": int(7.5 * EMU_PER_INCH),
            "cy": 10 * EMU_PER_INCH,
        },
    ]

    for deck in decks:
        slide_xml = build_slide_xml(deck["spec"], deck["cx"], deck["cy"])
        package_pptx(deck["output"], deck["image"], deck["cx"], deck["cy"], slide_xml)
        print(f"Generated {deck['output']}")


if __name__ == "__main__":
    main()
